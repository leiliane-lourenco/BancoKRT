# ---- build ----
FROM mcr.microsoft.com/dotnet/sdk:9.0 AS build
WORKDIR /src

# Copia o código e restaura/publica o projeto da API (puxa Application/Domain/Infrastructure).
COPY . .
RUN dotnet restore src/BancoKRT.GestaoLimite.Api/BancoKRT.GestaoLimite.Api.csproj
RUN dotnet publish src/BancoKRT.GestaoLimite.Api/BancoKRT.GestaoLimite.Api.csproj -c Release -o /app /p:UseAppHost=false

# ---- runtime ----
FROM mcr.microsoft.com/dotnet/aspnet:9.0 AS runtime
WORKDIR /app
COPY --from=build /app .

ENV ASPNETCORE_URLS=http://+:8080
EXPOSE 8080
ENTRYPOINT ["dotnet", "BancoKRT.GestaoLimite.Api.dll"]
