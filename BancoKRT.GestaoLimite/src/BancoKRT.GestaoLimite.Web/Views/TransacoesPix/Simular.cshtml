@model BancoKRT.GestaoLimite.Web.Models.BuscarContaPixViewModel
@{
    ViewData["Title"] = "Pesquisar conta";
}

<h2 class="mb-3">PIX</h2>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Buscar" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

            <div class="mb-3">
                <label asp-for="Documento" class="form-label"></label>
                <input asp-for="Documento" class="form-control" placeholder="CPF ou CNPJ" />
                <span asp-validation-for="Documento" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-dark">Pesquisar</button>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
