@model BancoKRT.GestaoLimite.Web.Models.SelecionarContaPixViewModel
@{
    ViewData["Title"] = "Selecionar conta";
}

<h2 class="mb-3">PIX</h2>
<p class="text-muted">
    Foram encontradas @Model.Contas.Count contas para o documento informado.
    Selecione a conta para continuar a transferência.
</p>

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead>
            <tr>
                <th>Documento</th>
                <th>Agência</th>
                <th>Conta</th>
                <th class="text-end">Saldo (R$)</th>
                <th class="text-end">Limite diário de PIX (R$)</th>
                <th class="text-center">Selecionar</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var conta in Model.Contas)
            {
                <tr>
                    <td>@conta.Documento</td>
                    <td>@conta.NumeroAgencia</td>
                    <td>@conta.NumeroConta</td>
                    <td class="text-end">@conta.Saldo.ToString("N2")</td>
                    <td class="text-end">@conta.LimitePix.ToString("N2")</td>
                    <td class="text-center">
                        <a class="btn btn-outline-dark btn-sm"
                           asp-action="Transferir"
                           asp-route-documento="@conta.Documento"
                           asp-route-numeroAgencia="@conta.NumeroAgencia"
                           asp-route-numeroConta="@conta.NumeroConta"
                           title="Transferir desta conta">
                            &rarr;
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<a class="btn btn-secondary" asp-action="Simular">Nova pesquisa</a>
